




python3 run.py

# Copy to .env for local development.  Never commit the real .env.
SECRET_KEY=replace-with-a-long-random-string

# Leave unset to use SQLite (instance/we_owe.db). For Sprint 2+ Postgres:
# DATABASE_URL=postgresql://user:pass@localhost:5432/we_owe

# Email: leave MAIL_SUPPRESS_SEND=1 to write mail to instance/outbox/ instead
# of sending. Set the SMTP_* values and MAIL_SUPPRESS_SEND=0 to send for real.
MAIL_SUPPRESS_SEND=1
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# MAIL_FROM=no-reply@weowe.app

# Set to 1 only when served over HTTPS
SESSION_COOKIE_SECURE=0
SECRET_KEY=your-secret-key

MAIL_SUPPRESS_SEND=0
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourgmail@gmail.com
SMTP_PASSWORD=your-google-app-password
MAIL_FROM=yourgmail@gmail.com
